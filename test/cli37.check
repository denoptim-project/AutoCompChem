#!/bin/bash

function not_passed() {
  echo "NOT Passed: check condition leading to line '$1' of '$0'"
  exit -1
}

# file created respecting the workDir configuration
if [ ! -f cli37_wdir/accOutput.inp ] ; then not_passed $LINENO ; fi
if [ ! -f cli37_wdir/accOutput.jd.json ] ; then not_passed $LINENO ; fi
if [ ! -f cli37_wdir/Job_#0.2_0/cli37.out ] ; then not_passed $LINENO ; fi

if [ ! -f cli37.log ] ; then not_passed $LINENO ; fi

n=0; n=$(grep -c -i "Termination status: 0" cli37.log)
if [ 1 == "$n" ] ; then echo Passed ; exit 0 ; fi
not_passed $LINENO
exit -1
