#!/bin/bash

function not_passed() {
  echo "NOT Passed: check condition leading to line '$1' of '$0'"
  exit -1
}

if [ ! -f cli47.log ] ; then not_passed $LINENO ; fi

n=0; n=$(grep -c -i "JobEvaluator: Situation perceived = draft_orca-e1.0_GeomOptRunOutOfCycles" cli47.log)
if [ 2 != "$n" ] ; then not_passed $LINENO ; fi

# Third job (i.e., second restart) is the successful one
if [ ! -d cli47_wdir ] ; then not_passed $LINENO ; fi

if [ ! -f cli47_wdir/cli47.out ] ; then not_passed $LINENO ; fi
if grep -q -i "The optimization did not converge but reached the maximum number" "cli47_wdir/cli47.out" ; then not_passed $LINENO ; fi

if [ ! -f cli47_wdir/cli47.gbw ] ; then not_passed $LINENO ; fi
if ! grep -q -i "last one." "cli47_wdir/cli47.gbw" ; then not_passed $LINENO ; fi

if [ -f cli47_wdir/cli47.densities ] ; then not_passed $LINENO ; fi # Not created to test removal in 2nd step

if [ ! -f cli47_wdir/restart.gbw ] ; then not_passed $LINENO ; fi
if ! grep -q -i "this should remain" "cli47_wdir/restart.gbw" ; then not_passed $LINENO ; fi
if ! grep -q -i "second attempt" "cli47_wdir/restart.gbw" ; then not_passed $LINENO ; fi

if [ ! -f cli47_wdir/restart.densities ] ; then not_passed $LINENO ; fi
if ! grep -q -i "this should remain" "cli47_wdir/restart.densities" ; then not_passed $LINENO ; fi
if ! grep -q -i "second attempt" "cli47_wdir/restart.densities" ; then not_passed $LINENO ; fi

# Second job (i.e., first restart) is the unsuccessful one
if [ ! -f "cli47_wdir/Job_#0.1_1/cli47.out" ] ; then not_passed $LINENO ; fi
if ! grep -q -i "The optimization did not converge but reached the maximum number" "cli47_wdir/Job_#0.1_1/cli47.out" ; then not_passed $LINENO ; fi

if [ -f cli47_wdir/Job_#0.1_1/restart.gbw ] ; then not_passed $LINENO ; fi # overwritten, so not archived

if [ ! -f cli47_wdir/Job_#0.1_1/cli47.gbw ] ; then not_passed $LINENO ; fi
if ! grep -q -i "this should remain" "cli47_wdir/Job_#0.1_1/cli47.gbw" ; then not_passed $LINENO ; fi
if ! grep -q -i "second attempt" "cli47_wdir/Job_#0.1_1/cli47.gbw" ; then not_passed $LINENO ; fi

if [ -f cli47_wdir/Job_#0.1_1/restart.densities ] ; then not_passed $LINENO ; fi # overwritten, so not archived

if [ ! -f cli47_wdir/Job_#0.1_1/cli47.densities ] ; then not_passed $LINENO ; fi
if ! grep -q -i "this should remain" "cli47_wdir/Job_#0.1_1/cli47.densities" ; then not_passed $LINENO ; fi
if ! grep -q -i "second attempt" "cli47_wdir/Job_#0.1_1/cli47.densities" ; then not_passed $LINENO ; fi

# First job (i.e., the originally' submitted job) was a compound job and was unsuccessful
if [ ! -f "cli47_wdir/Job_#0.1_1/Job_#0.1_0/cli47.out" ] ; then not_passed $LINENO ; fi
if ! grep -q -i "The optimization did not converge but reached the maximum number" "cli47_wdir/Job_#0.1_1/Job_#0.1_0/cli47.out" ; then not_passed $LINENO ; fi

n=0; n=$(grep -c -i "Termination status: 0" cli47.log)
if [ 1 == "$n" ] ; then echo Passed ; exit 0 ; fi
not_passed $LINENO
exit -1
