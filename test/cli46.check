#!/bin/bash

function not_passed() {
  echo "NOT Passed: check condition leading to line '$1' of '$0'"
  exit -1
}

if [ ! -d cli46_run ] ; then not_passed $LINENO ; fi

n=0; n=$(find cli46_run -mindepth 1 -maxdepth 1 -type d -name ".accJobData*" | wc -l | awk '{print $1}')
if [ 1 != "$n" ] ; then not_passed $LINENO ; fi

accDir=$(find cli46_run -mindepth 1 -maxdepth 1 -type d -name ".accJobData*")

if [ ! -d "cli46_run/cli46_nested_1" ] ; then not_passed $LINENO ; fi
if [ ! -d "cli46_run/cli46_nested_2" ] ; then not_passed $LINENO ; fi

# Check spilled data folder tree
if [ ! -d "$accDir" ] ; then not_passed $LINENO ; fi

if [ ! -d "$accDir/0" ] ; then not_passed $LINENO ; fi
if [ ! -f "$accDir/0/GENERATECONSTRAINTS_mol-0.nd.json" ] ; then not_passed $LINENO ; fi
n=0; n=$(grep -c -i "valuelessAttributes" "$accDir/0/GENERATECONSTRAINTS_mol-0.nd.json")
if [ 8 != "$n" ] ; then not_passed $LINENO ; fi

if [ ! -d "$accDir/1" ] ; then not_passed $LINENO ; fi
if [ ! -f "$accDir/1/mol-0_myDescriptor.nd.json" ] ; then not_passed $LINENO ; fi
n=0; n=$(grep -c -i "[2-6]\.[0-9]" "$accDir/1/mol-0_myDescriptor.nd.json")
if [ 4 != "$n" ] ; then not_passed $LINENO ; fi

if [ ! -d "$accDir/2" ] ; then not_passed $LINENO ; fi
if [ ! -d "$accDir/2/0" ] ; then not_passed $LINENO ; fi
if [ ! -f "$accDir/2/0/mol-0_myDescriptor.nd.json" ] ; then not_passed $LINENO ; fi
n=0; n=$(grep -c -i "[2-6]\.[0-9]" "$accDir/2/0/mol-0_myDescriptor.nd.json")
if [ 4 != "$n" ] ; then not_passed $LINENO ; fi

if [ ! -d "$accDir/2/1" ] ; then not_passed $LINENO ; fi
if [ ! -f "$accDir/2/1/GENERATECONSTRAINTS_mol-0.nd.json" ] ; then not_passed $LINENO ; fi
n=0; n=$(grep -c -i "valuelessAttributes" "$accDir/2/1/GENERATECONSTRAINTS_mol-0.nd.json")
if [ 6 != "$n" ] ; then not_passed $LINENO ; fi

if [ ! -f cli46.log ] ; then not_passed $LINENO ; fi

n=0; n=$(grep -c -i "Termination status: 0" cli46.log)
if [ 1 == "$n" ] ; then echo Passed ; exit 0 ; fi
not_passed $LINENO
exit -1
